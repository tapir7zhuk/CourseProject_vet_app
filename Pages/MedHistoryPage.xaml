<Page x:Class="CW_hammer.Pages.MedHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Медична історія">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ ЛІВО ═══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                Padding="10">
            <StackPanel>

                <!-- Фото -->
                <Border Height="180" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Image x:Name="PatientPhoto"
                               Stretch="Uniform" Margin="4"/>
                        <TextBlock x:Name="PatientNoPhoto"
                                   Text="Фото відсутнє"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.4" FontSize="12"/>
                    </Grid>
                </Border>

                <!-- Інфо -->
                <TextBlock x:Name="PatientName"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Власник:" Opacity="0.6"
                               Margin="0,3,8,3" FontSize="12"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="PatientOwner"
                               Grid.Row="0" Grid.Column="1"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,3"
                               Foreground="{DynamicResource TextBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Вид:" Opacity="0.6"
                               Margin="0,3,8,3" FontSize="12"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="PatientSpecies"
                               Grid.Row="1" Grid.Column="1"
                               FontSize="12" Margin="0,3"
                               Foreground="{DynamicResource TextBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Стать:" Opacity="0.6"
                               Margin="0,3,8,3" FontSize="12"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock x:Name="PatientSex"
                               Grid.Row="2" Grid.Column="1"
                               FontSize="12" Margin="0,3"
                               Foreground="{DynamicResource TextBrush}"/>
                </Grid>

                <!-- Кнопки -->
                <Separator Margin="0,8"/>

                <Button Content="💾 Зберегти"
                        Style="{DynamicResource AppButton}"
                        Margin="0,0,0,6"
                        Click="Save_Click"/>

                <Button Content="✕ Відмінити"
                        Style="{DynamicResource AppButton}"
                        Click="Cancel_Click"/>

            </StackPanel>
        </Border>

        <!-- РОЗДІЛЬНИК -->
        <Border Grid.Column="1"
                Background="{DynamicResource AccentBrush}"
                Opacity="0.2"/>

        <!-- ═══ ПРАВО: ФОРМА ═══ -->
        <Border Grid.Column="2"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock x:Name="FormTitle"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,20"/>

                    <!-- Хвороба -->
                    <TextBlock Text="Хвороба"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox x:Name="DiseaseCombo"
                              Height="32" Margin="0,0,0,14"
                              DisplayMemberPath="Name"
                              SelectedValuePath="ID"/>

                    <!-- Скарга -->
                    <TextBlock x:Name="ComplaintLabel"
                               Text="Скарга"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox x:Name="ComplaintBox"
                             Height="32" Margin="0,0,0,14"
                             Padding="8,6"/>

                    <!-- Призначення -->
                    <TextBlock x:Name="PrescriptionLabel"
                               Text="Призначення / Рецепт"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox x:Name="PrescriptionBox"
                             Height="80" Margin="0,0,0,14"
                             Padding="8,6"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <!-- Дата початку -->
                    <TextBlock Text="Дата початку"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <DatePicker x:Name="StartDatePicker"
                                Height="32" Margin="0,0,0,14"/>

                    <!-- Стан -->
                    <TextBlock Text="Стан"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox x:Name="StateCombo"
                              Height="32" Margin="0,0,0,14">
                        <ComboBoxItem Content="🔴 Активна"   Tag="true"  IsSelected="True"/>
                        <ComboBoxItem Content="✅ Завершена" Tag="false"/>
                    </ComboBox>

                    <!-- Дата завершення -->
                    <TextBlock Text="Дата завершення (якщо завершена)"
                               Opacity="0.6" Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}"/>
                    <DatePicker x:Name="EndDatePicker"
                                Height="32" Margin="0,0,0,14"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>