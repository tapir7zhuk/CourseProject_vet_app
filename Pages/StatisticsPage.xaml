<Page x:Class="CW_hammer.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 1. ЗАРАЗ ЛІКУЮТЬСЯ ═══ -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}">
            <StackPanel>
                <TextBlock Text="🏥 Зараз лікуються"
                           FontSize="15" FontWeight="Bold"
                           Margin="10,8"
                           Foreground="{DynamicResource TextBrush}"/>
                <DataGrid x:Name="TreatingGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Кличка"
                                            Binding="{Binding AnimalName}"  Width="100"/>
                        <DataGridTextColumn Header="Вид"
                                            Binding="{Binding Species}"     Width="80"/>
                        <DataGridTextColumn Header="Власник"
                                            Binding="{Binding OwnerName}"   Width="150"/>
                        <DataGridTextColumn Header="Хвороба"
                                            Binding="{Binding DiseaseName}" Width="130"/>
                        <DataGridTextColumn Header="Початок лікування"
                                            Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="130"/>
                        <DataGridTextColumn Header="Термін (днів)"
                                            Binding="{Binding DaysText}"    Width="110"/>
                        <DataGridTextColumn Header="Скарга"
                                            Binding="{Binding Complaint}"   Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource AccentBrush}" Opacity="0.2"/>

        <!-- ═══ 2. КІЛЬКІСТЬ ПО КАТЕГОРІЯМ ═══ -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}">
            <StackPanel>
                <TextBlock Text="📊 Кількість тварин по видах"
                           FontSize="15" FontWeight="Bold"
                           Margin="10,8"
                           Foreground="{DynamicResource TextBrush}"/>
                <DataGrid x:Name="CategoryGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0"
                          MaxHeight="180">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Вид"
                                            Binding="{Binding Species}"  Width="150"/>
                        <DataGridTextColumn Header="Всього"
                                            Binding="{Binding Total}"    Width="100"/>
                        <DataGridTextColumn Header="Живих"
                                            Binding="{Binding Alive}"    Width="100"/>
                        <DataGridTextColumn Header="Лікуються"
                                            Binding="{Binding Treating}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="{DynamicResource AccentBrush}" Opacity="0.2"/>

        <!-- ═══ 3. ЗАВЕРШИЛИ ЛІКУВАННЯ МИНУЛОГО МІСЯЦЯ ═══ -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}">
            <StackPanel>
                <TextBlock x:Name="LastMonthTitle"
                           FontSize="15" FontWeight="Bold"
                           Margin="10,8"
                           Foreground="{DynamicResource TextBrush}"/>
                <DataGrid x:Name="LastMonthGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Кличка"
                                            Binding="{Binding AnimalName}"  Width="100"/>
                        <DataGridTextColumn Header="Вид"
                                            Binding="{Binding Species}"     Width="80"/>
                        <DataGridTextColumn Header="Власник"
                                            Binding="{Binding OwnerName}"   Width="150"/>
                        <DataGridTextColumn Header="Хвороба"
                                            Binding="{Binding DiseaseName}" Width="130"/>
                        <DataGridTextColumn Header="Початок"
                                            Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Завершення"
                                            Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}"   Width="100"/>
                        <DataGridTextColumn Header="Тривалість (днів)"
                                            Binding="{Binding DaysText}"    Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

    </Grid>
</Page>