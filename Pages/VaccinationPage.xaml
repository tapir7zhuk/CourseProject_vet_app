<Page x:Class="CW_hammer.Pages.VaccinationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Щеплення">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛІВО: ІНФО ПРО ПАЦІЄНТА -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                Padding="10">
            <StackPanel>
                <Border Height="180" Margin="0,0,0,10"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Image x:Name="PatientPhoto" Stretch="Uniform" Margin="4"/>
                        <TextBlock x:Name="PatientNoPhoto"
                                   Text="Фото відсутнє"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.4" FontSize="12"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="PatientName"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="PatientOwner"
                           Opacity="0.6" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="PatientSpecies"
                           Opacity="0.6" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"/>

                <Separator Margin="0,10"/>

                <Button Content="💾 Зберегти"
                        Style="{DynamicResource AppButton}"
                        Margin="0,0,0,6"
                        Click="Save_Click"/>
                <Button Content="✕ Відмінити"
                        Style="{DynamicResource AppButton}"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource AccentBrush}" Opacity="0.2"/>

        <!-- ПРАВО: ФОРМА -->
        <Border Grid.Column="2"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                Padding="16">
            <StackPanel>

                <TextBlock Text="💉 Додати щеплення"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Виробник" Opacity="0.6" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox x:Name="ManufacturerBox"
                         Height="32" Margin="0,0,0,12" Padding="8,6"/>

                <TextBlock Text="Призначення" Opacity="0.6" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox x:Name="PurposeBox"
                         Height="32" Margin="0,0,0,12" Padding="8,6"/>

                <TextBlock Text="Серійний номер (6 цифр)" Opacity="0.6" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBox x:Name="SerialBox"
                         Height="32" Margin="0,0,0,12" Padding="8,6"
                         MaxLength="6"/>

                <TextBlock Text="Дата щеплення" Opacity="0.6" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextBrush}"/>
                <DatePicker x:Name="VaccineDatePicker"
                            Height="32" Margin="0,0,0,12"/>

                <TextBlock Text="Діє до" Opacity="0.6" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextBrush}"/>
                <DatePicker x:Name="ValidUntilPicker"
                            Height="32" Margin="0,0,0,12"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>