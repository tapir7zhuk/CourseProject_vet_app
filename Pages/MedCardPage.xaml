<Page x:Class="CW_hammer.Pages.MedCardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мед картка">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════════════ ВЕРХНЯ ЧАСТИНА ════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── ЛІВО: ФОТО ── -->
            <StackPanel Grid.Column="0">
                <Border Height="200"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Margin="0,0,0,6">
                    <Grid>
                        <Image x:Name="CardPhoto"
                               Stretch="Uniform" Margin="4"/>
                        <TextBlock x:Name="CardNoPhoto"
                                   Text="Фото відсутнє"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.4"/>
                    </Grid>
                </Border>

                <Button Content="🖼 Змінити фото"
                        Style="{DynamicResource AppButton}"
                        Margin="0,0,0,4" FontSize="11"
                        Click="ChangePhoto_Click"/>

                <Button Content="✏️ Редагувати дані"
                        Style="{DynamicResource AppButton}"
                        Margin="0,0,0,4" FontSize="11"
                        Click="EditAnimal_Click"/>

                <Button Content="🗑 Видалити"
                        Style="{DynamicResource AppButton}"
                        IsEnabled="False" FontSize="11"
                        Opacity="0.5"/>
            </StackPanel>

            <!-- РОЗДІЛЬНИК -->
            <Border Grid.Column="1"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0.2"/>

            <!-- ── ПРАВО: ТАБЛИЦІ 1 і 2 ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ТАБЛИЦЯ 1 — Дані тварини -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Картка тварини"
                                   FontWeight="Bold" Margin="8,6"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <DataGrid x:Name="AnimalTable"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Кличка"
                                                    Binding="{Binding Name}"        Width="80"/>
                                <DataGridTextColumn Header="Вид"
                                                    Binding="{Binding Species}"     Width="70"/>
                                <DataGridTextColumn Header="Порода"
                                                    Binding="{Binding Breed}"       Width="90"/>
                                <DataGridTextColumn Header="Забарвлення"
                                                    Binding="{Binding Coloring}"    Width="90"/>
                                <DataGridTextColumn Header="Нар."
                                                    Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="85"/>
                                <DataGridTextColumn Header="Стать"
                                                    Binding="{Binding SexText}"     Width="70"/>
                                <DataGridTextColumn Header="Стерил."
                                                    Binding="{Binding SterileText}" Width="65"/>
                                <DataGridTextColumn Header="Живий"
                                                    Binding="{Binding AliveText}"   Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ТАБЛИЦЯ 2 — Дані власника -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Власник"
                                   FontWeight="Bold" Margin="8,6"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <DataGrid x:Name="OwnerTable"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ім'я"
                                                    Binding="{Binding FirstName}" Width="90"/>
                                <DataGridTextColumn Header="Прізвище"
                                                    Binding="{Binding LastName}"  Width="100"/>
                                <DataGridTextColumn Header="Телефон"
                                                    Binding="{Binding Phone}"     Width="130"/>
                                <DataGridTextColumn Header="Адреса"
                                                    Binding="{Binding Address}"   Width="160"/>
                                <DataGridTextColumn Header="Місто"
                                                    Binding="{Binding City}"      Width="90"/>
                                <DataGridTextColumn Header="Індекс"
                                                    Binding="{Binding ZipCode}"   Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ГОРИЗОНТАЛЬНИЙ РОЗДІЛЬНИК -->
        <Border Grid.Row="1"
                Background="{DynamicResource AccentBrush}"
                Opacity="0.2"/>

        <!-- ════════════ НИЖНЯ ЧАСТИНА ════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ТАБЛИЦЯ 3 — Щеплення -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Щеплення"
                               FontWeight="Bold" Margin="8,6"
                               Foreground="{DynamicResource TextBrush}"/>
                    <DataGrid x:Name="VaccinationTable"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="✏️ Редагувати" Click="VaccEdit_Click"/>
                                <Separator/>
                                <MenuItem Header="🗑 Видалити"   Click="VaccDelete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding ID}"
                                                Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Виробник"
                                                Binding="{Binding Manufacturer}"  Width="110"/>
                            <DataGridTextColumn Header="Призначення"
                                                Binding="{Binding Purpose}"       Width="110"/>
                            <DataGridTextColumn Header="Серія"
                                                Binding="{Binding SerialNumber}"  Width="70"/>
                            <DataGridTextColumn Header="Дата"
                                                Binding="{Binding VaccinationDate, StringFormat=dd.MM.yyyy}" Width="85"/>
                            <DataGridTextColumn Header="Діє до"
                                                Binding="{Binding ValidUntil, StringFormat=dd.MM.yyyy}"      Width="85"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource AccentBrush}"
                    Opacity="0.2"/>

            <!-- ТАБЛИЦЯ 4 — Хвороби -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Історія хвороб"
                               FontWeight="Bold" Margin="8,6"
                               Foreground="{DynamicResource TextBrush}"/>
                    <DataGrid x:Name="DiseaseTable"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="✏️ Редагувати"   Click="DiseaseEdit_Click"/>
                                <MenuItem Header="🔄 Змінити стан" Click="DiseaseChangeState_Click"/>
                                <Separator/>
                                <MenuItem Header="🗑 Видалити"      Click="DiseaseDelete_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding ID}"
                                                Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Хвороба"
                                                Binding="{Binding DiseaseName}" Width="120"/>
                            <DataGridTextColumn Header="Початок"
                                                Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="80"/>
                            <DataGridTextColumn Header="Кінець"
                                                Binding="{Binding EndDate}"     Width="80"/>
                            <DataGridTextColumn Header="Стан"
                                                Binding="{Binding StateText}"   Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════ КНОПКИ ════════════ -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button Content="💉 Додати щеплення"
                    Style="{DynamicResource AppButton}"
                    Margin="0,0,8,0"
                    Click="AddVaccination_Click"/>
            <Button Content="🏥 Додати хворобу"
                    Style="{DynamicResource AppButton}"
                    Click="AddDisease_Click"/>
        </StackPanel>
    </Grid>
</Page>