<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- КОЛЬОРИ -->

    <SolidColorBrush x:Key="PrimaryBrush"    Color="#2D1B1B"/>
    <SolidColorBrush x:Key="AccentBrush"     Color="#E8613A"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#3D2020"/>
    <SolidColorBrush x:Key="SurfaceBrush"    Color="#4A2828"/>
    <SolidColorBrush x:Key="TextBrush"       Color="#FFE8E0"/>

    <!-- СТИЛЬ КНОПКИ -->
    <Style x:Key="AppButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Padding"         Value="16,10"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
